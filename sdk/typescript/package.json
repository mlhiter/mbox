{
  "name": "@mbox/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the mbox execution platform API.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:pack": "npm run build && node scripts/check-pack.mjs",
    "check:pack:consumer": "npm run build && node scripts/check-pack-consumer.mjs",
    "check:openapi": "npm run build && node scripts/check-openapi.mjs",
    "prepublishOnly": "npm run verify",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify": "npm run typecheck && npm run smoke && npm run check:pack && npm run check:pack:consumer"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
